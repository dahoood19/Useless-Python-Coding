-- == FLY STATE ==
local flyActive = false
local flyConnections = {}
local hoverTrack = nil
local flyTrack = nil
local isMoving = false

local FLIGHT_SPEED = 70

local function loadAnim(id)
	local animator = humanoid:FindFirstChildOfClass("Animator")
	if not animator then
		animator = Instance.new("Animator")
		animator.Parent = humanoid
	end
	local anim = Instance.new("Animation")
	anim.AnimationId = "rbxassetid://" .. id
	return animator:LoadAnimation(anim)
end

local function stopFly()
	flyActive = false

	if hoverTrack then hoverTrack:Stop() hoverTrack = nil end
	if flyTrack then flyTrack:Stop() flyTrack = nil end

	for _, conn in pairs(flyConnections) do
		conn:Disconnect()
	end
	flyConnections = {}

	local char = player.Character
	if char then
		local hrp = char:FindFirstChild("HumanoidRootPart")
		local hum = char:FindFirstChild("Humanoid")
		if hrp then
			hrp.Anchored = false
			hrp.AssemblyLinearVelocity = Vector3.zero
		end
		if hum then
			hum.PlatformStand = false
		end
	end

	isMoving = false
end

local function startFly()
	if flyActive then return end
	flyActive = true

	local char = player.Character
	if not char then return end
	local hrp = char:WaitForChild("HumanoidRootPart")
	local hum = char:WaitForChild("Humanoid")

	hrp.Anchored = true
	hum.PlatformStand = true

	hoverTrack = loadAnim(3541114300)
	hoverTrack.Looped = true
	hoverTrack:Play()

	flyTrack = loadAnim(3541044388)
	flyTrack.Looped = true

	local runConn = RunService.RenderStepped:Connect(function(dt)
		if not flyActive or not char or not hrp then return end

		local moveDir = hum.MoveDirection
		local isPressingMove = moveDir.Magnitude > 0.1

		local velocity = Vector3.zero

		if isPressingMove then
			local camLook = camera.CFrame.LookVector
			local camRight = camera.CFrame.RightVector

			local flat = Vector3.new(camLook.X, 0, camLook.Z).Unit
			local flatRight = Vector3.new(camRight.X, 0, camRight.Z).Unit

			local rawMove = hum.MoveDirection
			local forwardAmt = rawMove:Dot(flat)
			local rightAmt = rawMove:Dot(flatRight)

			local thrustDir = (camLook * forwardAmt + camRight * rightAmt)
			velocity = thrustDir * FLIGHT_SPEED
		end

		if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
			velocity = velocity + Vector3.new(0, FLIGHT_SPEED, 0)
		elseif UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
			velocity = velocity + Vector3.new(0, -FLIGHT_SPEED, 0)
		end

		hrp.CFrame = CFrame.new(hrp.Position + velocity * dt)
			* CFrame.fromEulerAnglesYXZ(0, select(2, camera.CFrame:ToEulerAnglesYXZ()), 0)

		local moving = velocity.Magnitude > 0.1
		if moving and not isMoving then
			isMoving = true
			if hoverTrack then hoverTrack:Stop() end
			if flyTrack then flyTrack:Play() end
		elseif not moving and isMoving then
			isMoving = false
			if flyTrack then flyTrack:Stop() end
			if hoverTrack then hoverTrack:Play() end
		end
	end)

	table.insert(flyConnections, runConn)
end

flyTool.Equipped:Connect(function()
	activation:Play()
	startFly()
end)

flyTool.Unequipped:Connect(function()
	activation:Play()
	stopFly()
end)

