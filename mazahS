local function toggleShazam(shirtId, pantsId, shirtGraphicId)
	character = player.Character or player.CharacterAdded:Wait()
	humanoid = character:WaitForChild("Humanoid")
	playShazamAnim()
	summonLightning()
	if isCustom then
		swapToOriginal()
	else
		swapToCustom(shirtId, pantsId, shirtGraphicId)
	end
end

player.Chatted:Connect(function(message)
	local lower = message:lower()
	local variant = variants[lower]
	if variant then
		toggleShazam(variant.shirt, variant.pants, variant.graphic)
	end
end)

