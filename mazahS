end

local function summonLightning()
	local torso = character:FindFirstChild("LowerTorso") or character:FindFirstChild("Torso")
	if torso then
		local sound = torso:FindFirstChild("lightning_bolt")
		if not sound then
			sound = Instance.new("Sound")
			sound.Name = "lightning_bolt"
			sound.SoundId = "rbxassetid://821439273"
			sound.Volume = 1
			sound.Looped = false
			sound.Parent = torso
		end
		sound:Play()
	end

	local angleRadians = math.rad(47)
	local totalLength = 300
	local horizontalOffset = math.sin(angleRadians) * totalLength
	local verticalOffset = math.cos(angleRadians) * totalLength
	local angle = math.rad(math.random(0, 360))
	local x = math.cos(angle) * horizontalOffset
	local z = math.sin(angle) * horizontalOffset
	local endPos = root.Position
	local startPos = endPos + Vector3.new(x, verticalOffset, z)
	local midpoint = (startPos + endPos) / 2

	local lightning = Instance.new("Part")
	lightning.Size = Vector3.new(3.8, 300, 3.8)
	lightning.Material = Enum.Material.Neon
	lightning.Color = Color3.fromRGB(210, 215, 120)
	lightning.Anchored = true
	lightning.CanCollide = false
	lightning.CFrame = CFrame.new(midpoint, endPos) * CFrame.Angles(math.rad(90), 0, 0)
	lightning.Parent = workspace
	local tween = TweenService:Create(lightning, TweenInfo.new(1.85), {Transparency = 1})
	tween:Play()
	tween.Completed:Once(function() lightning:Destroy() end)
end

local function addCape()
	local torso = character:FindFirstChild("UpperTorso") or character:FindFirstChild("Torso")
	if not torso then return end

	-- remove old cape
	local old = character:FindFirstChild("ShazamCapeHandle")
	if old then old:Destroy() end

	-- HANDLE
	local handle = Instance.new("Part")
	handle.Name = "ShazamCapeHandle"
	handle.Size = Vector3.new(2, 3, 0.1)
	handle.CanCollide = false
	handle.Massless = true
	handle.Color = Color3.fromRGB(255, 255, 255)
	handle.Parent = character

	-- MESH
	local mesh = Instance.new("SpecialMesh")
	mesh.MeshType = Enum.MeshType.FileMesh
	mesh.MeshId = "rbxassetid://114046169"
	mesh.TextureId = ""
	mesh.Scale = Vector3.new(1.457, 1.9, 1.279)
	mesh.Parent = handle

	-- WELD (Motor6D like you wanted)
	local weld = Instance.new("Motor6D")
	weld.Name = "CapeWeld"
	weld.Part0 = torso
	weld.Part1 = handle
	weld.C0 = CFrame.new(0, -1.0, 0.45)
	weld.Parent = torso

	-- 🔥 SCALE SUPPORT (keeps it matching your size system)
	local humanoid = character:WaitForChild("Humanoid")
	local originalScale = mesh.Scale

	local function update()
		local h = humanoid:FindFirstChild("BodyHeightScale") and humanoid.BodyHeightScale.Value or 1
		local w = humanoid:FindFirstChild("BodyWidthScale") and humanoid.BodyWidthScale.Value or 1
		local d = humanoid:FindFirstChild("BodyDepthScale") and humanoid.BodyDepthScale.Value or 1

		mesh.Scale = Vector3.new(
			originalScale.X * w,
			originalScale.Y * h,
			originalScale.Z * d
		)
	end

	update()

	for _, n in ipairs({"BodyHeightScale","BodyWidthScale","BodyDepthScale"}) do
		local s = humanoid:FindFirstChild(n)
		if s then
			s:GetPropertyChangedSignal("Value"):Connect(update)
		end
	end

	table.insert(addedAccessories, handle)
end

local function swapToCustom(shirtId, pantsId, shirtGraphicId)
	local s = character:FindFirstChildOfClass("Shirt")
	if s then originalShirt = s:Clone() end
	local p = character:FindFirstChildOfClass("Pants")
	if p then originalPants = p:Clone() end

	for _, v in ipairs(character:GetChildren()) do
		if v:IsA("Shirt") or v:IsA("Pants") or v:IsA("ShirtGraphic") then v:Destroy() end
	end
	addedAccessories = {}

	local shirt = Instance.new("Shirt")
	shirt.ShirtTemplate = "rbxassetid://" .. shirtId
	shirt.Parent = character

	local pants = Instance.new("Pants")
	pants.PantsTemplate = "rbxassetid://" .. pantsId
	pants.Parent = character

	addCape()
	flyTool.Parent = player.Backpack
	humanoid.MaxHealth = 1000
	humanoid.Health = 1000
	isCustom = true
end

local function swapToOriginal()
	for _, v in ipairs(character:GetChildren()) do
		if v:IsA("Shirt") or v:IsA("Pants") then v:Destroy() end
	end
	local torso = character:FindFirstChild("UpperTorso") or character:FindFirstChild("Torso")
	if torso then
		local capeWeld = torso:FindFirstChild("CapeWeld")
		if capeWeld then capeWeld:Destroy() end
	end
	for _, acc in ipairs(addedAccessories) do
		if acc and acc.Parent then acc:Destroy() end
	end
	addedAccessories = {}
	if originalShirt then originalShirt:Clone().Parent = character end
	if originalPants then originalPants:Clone().Parent = character end
	flyTool.Parent = nil
	stopFly()
	humanoid.MaxHealth = 100
	humanoid.Health = math.min(humanoid.Health, 100)
	isCustom = false
end

