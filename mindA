local function updateHideButtonPos()
	local screenSize = workspace.CurrentCamera.ViewportSize
	local absX = PANEL_POS.X.Scale * screenSize.X + PANEL_POS.X.Offset
	local absY = PANEL_POS.Y.Scale * screenSize.Y + PANEL_POS.Y.Offset
	if panelHidden then
		hideButton.Position = UDim2.new(0, screenSize.X - hideButton.Size.X.Offset, 0, absY + 35)
	else
		hideButton.Position = UDim2.new(0, absX - 69, 0, absY + 35)
	end
end
updateHideButtonPos()

local setESPVisible

local function easeOutCubic(t) return 1 - (1 - t) ^ 3 end

local function slidePanel(toHide)
	if isAnimating then return end
	isAnimating = true
	local screenSize = workspace.CurrentCamera.ViewportSize
	local btnW = hideButton.Size.X.Offset
	local absY = PANEL_POS.Y.Scale * screenSize.Y + PANEL_POS.Y.Offset
	local STEPS = 50
	local DURATION = 0.55
	if toHide then
		hideButton.Text = "Show"
		local startXpx = PANEL_POS.X.Scale * screenSize.X + PANEL_POS.X.Offset
		local targetXpx = screenSize.X
		for i = 1, STEPS do
			local eased = easeOutCubic(i / STEPS)
			local newXpx = startXpx + (targetXpx - startXpx) * eased
			local newBtnX = math.min(newXpx - 69, screenSize.X - btnW)
			mainFrame.Position = UDim2.new(0, newXpx, PANEL_POS.Y.Scale, PANEL_POS.Y.Offset)
			hideButton.Position = UDim2.new(0, newBtnX, 0, absY + 35)
			task.wait(DURATION / STEPS)
		end
		mainFrame.Position = UDim2.new(0, screenSize.X, PANEL_POS.Y.Scale, PANEL_POS.Y.Offset)
		hideButton.Position = UDim2.new(0, screenSize.X - btnW, 0, absY + 35)
		panelHidden = true
		setESPVisible(false)
	else
		hideButton.Text = "Hide"
		local startXpx = screenSize.X
		local targetXpx = PANEL_POS.X.Scale * screenSize.X + PANEL_POS.X.Offset
		for i = 1, STEPS do
			local eased = easeOutCubic(i / STEPS)
			local newXpx = startXpx + (targetXpx - startXpx) * eased
			local newBtnX = math.min(newXpx - 69, screenSize.X - btnW)
			mainFrame.Position = UDim2.new(0, newXpx, PANEL_POS.Y.Scale, PANEL_POS.Y.Offset)
			hideButton.Position = UDim2.new(0, newBtnX, 0, absY + 35)
			task.wait(DURATION / STEPS)
		end
		mainFrame.Position = PANEL_POS
		panelHidden = false
		updateHideButtonPos()
		setESPVisible(true)
	end
	isAnimating = false
end

hideButton.MouseButton1Click:Connect(function()
