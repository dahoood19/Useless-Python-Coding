local playerRows = {}
local originalRowHeight = 50

local function updateAllRowPositions()
	local sortedPlayers = {}
	for playerName in pairs(playerRows) do
		table.insert(sortedPlayers, playerName)
	end
	table.sort(sortedPlayers, function(a, b) return a < b end)
	for i, playerName in ipairs(sortedPlayers) do
		local row = playerRows[playerName]
		if row then
			local yOffset = (i - 1) * originalRowHeight
			for buttonName, button in pairs(row.buttons) do
				local originalButton = originalButtons[buttonName]
				if originalButton then
					local op = originalButton.Position
					button.Position = UDim2.new(op.X.Scale, op.X.Offset, op.Y.Scale, op.Y.Offset + yOffset)
				end
			end
			row.rowIndex = i
		end
	end
end

local function removePlayerRow(playerName)
	local row = playerRows[playerName]
	if row then
		for _, button in pairs(row.buttons) do button:Destroy() end
		playerRows[playerName] = nil
		updateAllRowPositions()
	end
end

local spectatedPlayer = nil

local function getOriginCharacter()
	if spectatedPlayer and spectatedPlayer.Character then
		return spectatedPlayer.Character
	end
	return player.Character
end

local function createPlayerRow(targetPlayer, rowIndex)
	local playerName = targetPlayer.Name
	local isLocalPlayer = (targetPlayer == player)
	local yOffset = (rowIndex - 1) * originalRowHeight
	local newRowButtons = {}

	for buttonName, originalButton in pairs(originalButtons) do
		local cloned = originalButton:Clone()
		cloned.Name = buttonName .. "_" .. playerName
		cloned.Parent = banLogic
		cloned.Visible = true
		local op = originalButton.Position
		cloned.Position = UDim2.new(op.X.Scale, op.X.Offset, op.Y.Scale, op.Y.Offset + yOffset)

		if buttonName == "BanUsername" then
			cloned.Text = playerName
			if isLocalPlayer then
				cloned.BackgroundColor3 = Color3.new(0.792157, 0, 0)
			end
		elseif buttonName == "SpectateButton" then
			cloned.Text = "Spectate"
		elseif buttonName == "BanReason" then
			cloned.Text = ""
			cloned.PlaceholderText = ""
			local lbl = cloned:FindFirstChildOfClass("TextLabel")
			if lbl then lbl.Visible = true end
			cloned.Focused:Connect(function()
				if lbl then lbl.Visible = false end
			end)
			cloned.FocusLost:Connect(function()
				if lbl then lbl.Visible = cloned.Text == "" end
			end)
		end

		newRowButtons[buttonName] = cloned

		if cloned:IsA("TextButton") then
			applyButtonEffect(cloned)
			cloned.MouseButton1Click:Connect(function()
				if buttonName == "SpectateButton" then
					if isLocalPlayer then return end
					local cam = workspace.CurrentCamera
					local myHumanoid = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
					local targetChar = targetPlayer.Character
					local targetHumanoid = targetChar and targetChar:FindFirstChildOfClass("Humanoid")
					if not targetHumanoid then return end
					if cam.CameraSubject == targetHumanoid then
						spectatedPlayer = nil
						if myHumanoid then
							cam.CameraSubject = myHumanoid
							cam.CameraType = Enum.CameraType.Custom
						end
					else
						cam.CameraType = Enum.CameraType.Custom
						cam.CameraSubject = targetHumanoid
						spectatedPlayer = targetPlayer
					end
				end
			end)
		end
	end

	playerRows[playerName] = { buttons = newRowButtons, rowIndex = rowIndex }

	task.spawn(function()
		local famousGroup = getFamousGroupName(targetPlayer)
		local row = playerRows[playerName]
		if not row then return end
		local banBtn = row.buttons["BanUsername"]
		if not banBtn then return end
		if famousGroup then
			banBtn.Text = playerName .. "\n" .. famousGroup
			banBtn.TextScaled = true
		end
	end)
end

