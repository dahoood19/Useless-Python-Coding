--  GROUP CACHE
-- ─────────────────────────────────────────────
local groupCache = {}

local function getFamousGroupName(targetPlayer)
	if groupCache[targetPlayer.UserId] ~= nil then
		return groupCache[targetPlayer.UserId]
	end
	local success, groups = pcall(function()
		return GroupService:GetGroupsAsync(targetPlayer.UserId)
	end)
	if success and groups then
		for _, g in ipairs(groups) do
			if g.MemberCount and g.MemberCount >= 30000 then
				groupCache[targetPlayer.UserId] = g.Name
				return g.Name
			end
		end
	end
	groupCache[targetPlayer.UserId] = false
	return false
end

