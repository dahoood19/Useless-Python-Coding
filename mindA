local beamParts = {}

local rayParams = RaycastParams.new()
rayParams.FilterType = Enum.RaycastFilterType.Exclude

local function hasGunScript(character)
	for _, item in ipairs(character:GetChildren()) do
		if item:IsA("Tool") then
			for _, child in ipairs(item:GetChildren()) do
				if child:IsA("Script") and child.Name == "GunScript" then
					return true
				end
			end
		end
	end
	return false
end

local function getAimedTarget(headPos, lookDir, excludeCharacter)
	local bestDot = AIM_DOT_THRESHOLD
	local bestPos = nil
	for _, p in ipairs(Players:GetPlayers()) do
		if not p.Character or p.Character == excludeCharacter then continue end
		local torso = p.Character:FindFirstChild("UpperTorso") or p.Character:FindFirstChild("Torso")
		if not torso then continue end
		if (torso.Position - headPos).Magnitude > PROXIMITY then continue end
		local dot = lookDir:Dot((torso.Position - headPos).Unit)
		if dot > bestDot then
			bestDot = dot
			bestPos = torso.Position
		end
	end
	return bestPos
end

local function getOrCreateBeam(userId)
	if beamParts[userId] and beamParts[userId].Parent then
		return beamParts[userId]
	end
	local part = Instance.new("Part")
	part.Name = "AimBeam_" .. userId
	part.Anchored = true
	part.CanCollide = false
	part.CanQuery = false
	part.CastShadow = false
	part.Material = Enum.Material.Neon
	part.Color = Color3.fromRGB(255, 0, 0)
	part.Transparency = 0.15
	part.Size = Vector3.new(0, 0, 0)
	part.CFrame = CFrame.new(0, -10000, 0)
	part.Parent = workspace
	beamParts[userId] = part
	return part
end

local function hideBeam(userId)
	local b = beamParts[userId]
	if b and b.Parent then
		b.Size = Vector3.new(0, 0, 0)
		b.CFrame = CFrame.new(0, -10000, 0)
	end
end

local function updateBeam(userId, fromPos, toPos)
	local length = (toPos - fromPos).Magnitude
	if length < 0.1 then hideBeam(userId) return end
	local beam = getOrCreateBeam(userId)
	local mid = (fromPos + toPos) / 2
	local dir = (toPos - fromPos).Unit
	beam.Size = Vector3.new(0.12, 0.12, length)
	beam.CFrame = CFrame.lookAt(mid, mid + dir)
end

local function destroyBeam(userId)
	local b = beamParts[userId]
	if b and b.Parent then b:Destroy() end
	beamParts[userId] = nil
end

local function getProximityOriginPos()
	local originChar = getOriginCharacter()
	if not originChar then return nil end
	local torso = originChar:FindFirstChild("UpperTorso") or originChar:FindFirstChild("Torso")
	return torso and torso.Position or nil
end

RunService.Heartbeat:Connect(function()
	if not mainFrame.Visible then
		for userId in pairs(beamParts) do hideBeam(userId) end
		return
	end

	local myPos = getProximityOriginPos()

	for _, p in ipairs(Players:GetPlayers()) do
		if p == player then continue end
		if spectatedPlayer and p == spectatedPlayer then continue end

		local character = p.Character
		if not character then hideBeam(p.UserId) continue end

		if not hasGunScript(character) then hideBeam(p.UserId) continue end

		if myPos then
			local theirTorso = character:FindFirstChild("UpperTorso") or character:FindFirstChild("Torso")
			if not theirTorso or (theirTorso.Position - myPos).Magnitude > PROXIMITY then
				hideBeam(p.UserId)
				continue
			end
		else
			hideBeam(p.UserId)
			continue
		end

		local head = character:FindFirstChild("Head")
		local rHand = character:FindFirstChild("RightHand")
		if not head or not rHand then hideBeam(p.UserId) continue end

		local headPos = head.Position
		local lookDir = head.CFrame.LookVector
		local target = getAimedTarget(headPos, lookDir, character)
		if not target then hideBeam(p.UserId) continue end

		rayParams.FilterDescendantsInstances = { character }
		local result = workspace:Raycast(rHand.Position, lookDir * 500, rayParams)
		local endPos = result and result.Position or (rHand.Position + lookDir * 500)
		updateBeam(p.UserId, rHand.Position, endPos)
	end
end)

