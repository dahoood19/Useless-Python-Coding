local function refreshPlayerList()
	for _, row in pairs(playerRows) do
		for _, button in pairs(row.buttons) do button:Destroy() end
	end
	playerRows = {}

	local allPlayers = {}
	for _, p in ipairs(Players:GetPlayers()) do
		table.insert(allPlayers, p)
	end
	table.sort(allPlayers, function(a, b) return a.Name < b.Name end)

	for rowIndex, p in ipairs(allPlayers) do
		createPlayerRow(p, rowIndex)
	end
end

Players.PlayerAdded:Connect(function(newPlayer)
	refreshPlayerList()
end)

Players.PlayerRemoving:Connect(function(leftPlayer)
	local cam = workspace.CurrentCamera
	local leftHumanoid = leftPlayer.Character and leftPlayer.Character:FindFirstChildOfClass("Humanoid")
	if leftHumanoid and cam.CameraSubject == leftHumanoid then
		spectatedPlayer = nil
		local myHumanoid = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
		if myHumanoid then
			cam.CameraSubject = myHumanoid
			cam.CameraType = Enum.CameraType.Custom
		end
	end
	removePlayerRow(leftPlayer.Name)
end)

