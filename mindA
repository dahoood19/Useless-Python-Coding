local BLUE = Color3.fromRGB(215, 255, 255)
local RED  = Color3.fromRGB(255, 0, 0)

local function getOriginPosition()
	local originChar = getOriginCharacter()
	if originChar then
		local torso = originChar:FindFirstChild("UpperTorso") or originChar:FindFirstChild("Torso")
		if torso then return torso.Position end
	end
	return nil
end

local function isNearOrigin(targetCharacter)
	local origin = getOriginPosition()
	if not origin then return false end
	local torso = targetCharacter:FindFirstChild("UpperTorso") or targetCharacter:FindFirstChild("Torso")
	if not torso then return false end
	return (torso.Position - origin).Magnitude <= PROXIMITY
end

local function applyESP(espPlayer, character)
	if espPlayer == player and HIDE_LOCAL_PLAYER_ESP then return end

	local torso = character:FindFirstChild("UpperTorso") or character:FindFirstChild("Torso")
	if not torso then return end

	local existing = torso:FindFirstChild("ESP")
	if existing then existing:Destroy() end

	local isMe = espPlayer == player
	local isNear = not isMe and isNearOrigin(character)
	local nameColor = (isMe or isNear) and BLUE or RED

	local famousGroup = not isMe and getFamousGroupName(espPlayer) or false
	local billboardHeight = famousGroup and 38 or 22

	local billboard = Instance.new("BillboardGui")
	billboard.Name = "ESP"
	billboard.Adornee = torso
	billboard.Size = UDim2.new(0, 200, 0, billboardHeight)
	billboard.AlwaysOnTop = true
	billboard.StudsOffset = Vector3.new(0, 0, 0)
	billboard.Enabled = mainFrame.Visible
	billboard.Parent = torso

	local nameLabel = Instance.new("TextLabel")
	nameLabel.Name = "NameLabel"
	nameLabel.Size = famousGroup and UDim2.new(1, 0, 0.5, 0) or UDim2.new(1, 0, 1, 0)
	nameLabel.Position = UDim2.new(0, 0, 0, 0)
	nameLabel.BackgroundTransparency = 1
	nameLabel.TextScaled = false
	nameLabel.TextSize = 35
	nameLabel.Font = Enum.Font.SourceSansSemibold
	nameLabel.Text = espPlayer.Name
	nameLabel.TextColor3 = isMe and BLUE or nameColor
	nameLabel.Parent = billboard

	if famousGroup then
		local subLabel = Instance.new("TextLabel")
		subLabel.Name = "SubLabel"
		subLabel.Size = UDim2.new(1, 0, 0.5, 0)
		subLabel.Position = UDim2.new(0, 0, 0.5, 0)
		subLabel.BackgroundTransparency = 1
